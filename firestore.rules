rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isPrincipal() {
      return isSignedIn() && request.auth.token.role == "principal";
    }

    match /{document=**} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && !isPrincipal();
    }
  }
}
